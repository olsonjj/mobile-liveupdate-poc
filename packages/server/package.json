{
  "name": "@ionic-update-poc/server",
  "version": "0.0.0",
  "private": true,
  "description": "Fastify + TypeScript local server serving update manifests and payload zips (POC).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
