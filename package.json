{
  "name": "ionic-update-poc",
  "version": "0.0.0",
  "private": true,
  "description": "Roll-your-own Ionic/Capacitor live updates POC (monorepo scaffolding).",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev:app": "pnpm --filter @ionic-update-poc/app dev",
    "dev:server": "pnpm --filter @ionic-update-poc/server dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ],
    "ignoredOptionalDependencies": [
      "@angular/animations"
    ]
  }
}
