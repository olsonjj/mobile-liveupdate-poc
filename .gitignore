# Dependencies
node_modules/

# Build output
dist/
www/
build/

# Angular CLI cache
.angular/

# Screenshots (throwaway simulator verification artifacts — only the
# README example image is tracked, the rest stay local)
screenshots/*
!screenshots/app-home.png

# Capacitor / iOS
packages/app/ios/App/App/output/
packages/app/ios/App/build/
packages/app/ios/App/Pods/
