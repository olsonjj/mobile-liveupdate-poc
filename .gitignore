# Inlined live-update plugin (local SPM package) build artifacts
packages/app/live-update-plugin/.build/
packages/app/live-update-plugin/.swiftpm/
packages/app/live-update-plugin/Package.resolved

# Server payloads (generated zips, kept local)
packages/server/payloads/*.zip

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
.vscode/
.idea/
